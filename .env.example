# NexaSearch Configuration Settings

DEBUG=true
PROJECT_NAME="NexaSearch"

# Path configuration (Relative to project root)
DUCKDB_PATH="data/nexasearch.db"
INDEX_DIR="data/index"

# Crawling Settings
CRAWL_MAX_DEPTH=2
CRAWL_MAX_PAGES=50
CRAWL_CONCURRENT=5
CRAWL_TIMEOUT=30
CRAWL_USER_AGENT="NexaSearchCrawler/0.1.0"
CRAWL_KEYWORDS="AI,LLM,agent,machine learning,deep learning,neural network,python,pypi,research paper,arxiv,github"

# Quality Filtering Settings
QUALITY_THRESHOLD=0.6
MIN_WORD_COUNT=50
MAX_WORD_COUNT=10000
USE_DISTILBERT_CLASSIFIER=false

# Deduplication Settings
JACCARD_THRESHOLD=0.85
NUM_PERMUTATIONS=128

# Semantic Chunking Settings
CHUNK_SIZE=512
CHUNK_OVERLAP=100

# Search & Reranking Models
# Standard lightweight sentence-transformer model
EMBEDDING_MODEL_NAME="sentence-transformers/all-MiniLM-L6-v2"
# Ms-Marco cross encoder for reranking
CROSS_ENCODER_MODEL_NAME="cross-encoder/ms-marco-MiniLM-L-6-v2"

# Reranking Weight (0.0 to 1.0)
# Composite score = BM25_weight * BM25_score + Vector_weight * Vector_score
BM25_WEIGHT=0.5
VECTOR_WEIGHT=0.5
QUALITY_WEIGHT=0.2 # Added booster weight

# External API Keys (Optional, for JIT router/RAG)
GITHUB_TOKEN=""
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""
